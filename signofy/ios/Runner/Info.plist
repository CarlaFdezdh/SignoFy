<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- ─── Identificación ──────────────────────────────────────────── -->
	<key>CFBundleDevelopmentRegion</key>
	<string>es</string>
	<key>CFBundleDisplayName</key>
	<string>SignoFy</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>signofy</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>0.1.0</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>1</string>

	<!-- ─── Orientación (solo portrait) ────────────────────────────── -->
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
	</array>

	<!-- ─── Permisos con descripciones en español ───────────────────── -->
	<!-- Cámara: reconocimiento de signos (feature futura) -->
	<key>NSCameraUsageDescription</key>
	<string>SignoFy necesita acceso a la cámara para reconocer los signos que haces con tus manos y darte feedback en tiempo real.</string>
	
	<!-- Red: acceso a LSE-Sign BCBL y reproducción de vídeos -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<!-- Permite HTTP para lse-sign.bcbl.eu (el portal usa HTTP) -->
		<key>NSExceptionDomains</key>
		<dict>
			<key>lse-sign.bcbl.eu</key>
			<dict>
				<key>NSExceptionAllowsInsecureHTTPLoads</key>
				<true/>
				<key>NSIncludesSubdomains</key>
				<true/>
			</dict>
		</dict>
	</dict>

	<!-- ─── Flutter ─────────────────────────────────────────────────── -->
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>

	<!-- ─── Splash Screen ───────────────────────────────────────────── -->
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>

	<!-- ─── Main storyboard ─────────────────────────────────────────── -->
	<key>UIMainStoryboardFile</key>
	<string>Main</string>

	<!-- ─── Barra de estado: iconos blancos (fondo oscuro) ──────────── -->
	<key>UIStatusBarStyle</key>
	<string>UIStatusBarStyleLightContent</string>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<false/>
</dict>
</plist>
